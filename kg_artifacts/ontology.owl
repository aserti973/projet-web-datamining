<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://cinema-controversy.org/ontology.owl"
         xmlns="http://cinema-controversy.org/ontology.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://cinema-controversy.org/ontology.owl"/>

<owl:ObjectProperty rdf:about="#actedIn">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Film"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#directed">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Film"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#workedWith">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Film">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Quentin_Tarantino">
  <rdf:type rdf:resource="#Person"/>
  <directed rdf:resource="#Pulp_Fiction"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Uma_Thurman">
  <rdf:type rdf:resource="#Person"/>
  <actedIn rdf:resource="#Pulp_Fiction"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pulp_Fiction">
  <rdf:type rdf:resource="#Film"/>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#p1"/>

<swrl:Variable rdf:about="urn:swrl#f"/>

<swrl:Variable rdf:about="urn:swrl#p2"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Person"/>
          <swrl:argument1 rdf:resource="urn:swrl#p1"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#actedIn"/>
              <swrl:argument1 rdf:resource="urn:swrl#p1"/>
              <swrl:argument2 rdf:resource="urn:swrl#f"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:ClassAtom>
                  <swrl:classPredicate rdf:resource="#Person"/>
                  <swrl:argument1 rdf:resource="urn:swrl#p2"/>
                </swrl:ClassAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#directed"/>
                      <swrl:argument1 rdf:resource="urn:swrl#p2"/>
                      <swrl:argument2 rdf:resource="urn:swrl#f"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#workedWith"/>
          <swrl:argument1 rdf:resource="urn:swrl#p1"/>
          <swrl:argument2 rdf:resource="urn:swrl#p2"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
